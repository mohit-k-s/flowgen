# AWS region where Bedrock is enabled
## There are no secrets in this file so it can be added to version control
VITE_AWS_REGION=ap-south-1

# Bedrock model ID (Amazon Nova Pro)
VITE_BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# No credentials needed here — the Vite dev server runs in Node.js and reads
# ~/.aws/credentials automatically via the AWS SDK credential provider chain.
# Run: aws configure  (or set AWS_PROFILE=your-profile for named profiles)
